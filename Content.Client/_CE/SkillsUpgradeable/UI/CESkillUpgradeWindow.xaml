<ce:CESkillUpgradeWindow
    xmlns="https://spacestation14.io"
    xmlns:ce="clr-namespace:Content.Client._CE.SkillsUpgradeable.UI"
    Title="{Loc 'ce-skill-upgrade-window-title'}"
    MinSize="800 500"
    SetSize="1000 600"
    MaxSize="1200 600">
    <BoxContainer Orientation="Vertical" HorizontalExpand="True" VerticalExpand="True">
        <PanelContainer StyleClasses="AngleRect" Margin="8">
            <BoxContainer Orientation="Vertical" HorizontalAlignment="Center" Margin="12,6,12,6">
                <Label Name="LevelLabel" Text="Level up to level 2"
                       StyleClasses="LabelHeadingBigger"
                       HorizontalAlignment="Center" />
                <Label Text="{Loc 'ce-skill-upgrade-window-header'}"
                       StyleClasses="LabelSubText"
                       HorizontalAlignment="Center"
                       Margin="0,2,0,0" />
            </BoxContainer>
        </PanelContainer>

        <ScrollContainer VerticalExpand="True" HorizontalExpand="True" HScrollEnabled="True" VScrollEnabled="False" Margin="8,4,8,8">
            <BoxContainer Orientation="Horizontal" Name="SkillsList" SeparationOverride="12" HorizontalAlignment="Center" />
        </ScrollContainer>
    </BoxContainer>
</ce:CESkillUpgradeWindow>
